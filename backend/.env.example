PORT=4000
FRONTEND_URL=http://localhost:5173

# Auth
JWT_SECRET=change-me-to-something-random

# Database - defaults to zero-config SQLite. To use Postgres/MySQL instead,
# set DB_DIALECT=postgres (or mysql/mssql) and DB_URL=postgres://user:pass@host:5432/dbname
DB_DIALECT=sqlite

# Social login - leave blank to disable a provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
